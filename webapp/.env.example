# Supabase — public, RLS-protected credentials (safe to ship to the browser).
# Copy to `.env.local` and fill from the Supabase project's API settings.
# When unset, the app still runs: auth/session simply stays disabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Yandex Maps JavaScript API (v2.1) key — switches every map (landing showcase,
# /explore, location pickers) from OSM/Leaflet tiles to Yandex cartography.
# When unset (or the script fails to load), the maps fall back to OSM.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# Sentry — client + server error monitoring, performance tracing, and session
# replay for errored sessions. See instrumentation-client.ts and
# sentry.server.config.ts for the sampling rates.
#
# DSN is public (embedded in the browser bundle) — use `NEXT_PUBLIC_*` so it's
# visible in Client Components. `SENTRY_DSN` (without the prefix) is picked up
# on the server as a fallback so a single env value can drive both runtimes.
# When unset, Sentry initialises to a no-op and no events leave the process.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload — only used at BUILD TIME by @sentry/nextjs to push
# minified .map files to your Sentry org so stack traces resolve to the
# original TypeScript source. `SENTRY_AUTH_TOKEN` is a Sentry API key with the
# `project:releases` scope (Sentry → Settings → Auth Tokens). Never expose it
# to the browser — no `NEXT_PUBLIC_` prefix.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Mobile app deep-link verification — served from /.well-known/.
#
# Android App Links: SHA-256 of the release keystore certificate. Comma-
# separated when you have both upload and Play-App-Signing fingerprints
# during rollout. Format is 32 upper-case hex bytes joined by colons,
# e.g. "14:6D:E9:...:B3". Extract with:
#   keytool -list -v -keystore <keystore>.jks -alias upload
# See docs/android-signing.md §4. Without this env the /.well-known/
# assetlinks.json endpoint still responds 200 but Android won't verify.
ANDROID_APP_SHA256_FINGERPRINT=

# iOS Universal Links: 10-char Apple Developer Team ID (Apple Developer
# Portal → Membership → Team ID). Combined with the bundle id it forms
# the appID that /.well-known/apple-app-site-association returns.
IOS_APP_TEAM_ID=

# ─── Canonical site URL ─────────────────────────────────────────────────────
# Used by lib/seo.ts (siteUrl), JSON-LD, sitemap.ts, robots.ts, canonical
# links, and every generated `${siteUrl()}/…` URL. MUST match the domain
# you point DNS at. Include the scheme + host with no trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.yollla.uz

# ─── Supabase service role (SERVER-ONLY) ────────────────────────────────────
# Required for the admin panel to read across owners (users list, moderation
# queues, finance) and to run the Auth Admin API (ban / delete-user) from
# server actions. NEVER expose this to the browser — no NEXT_PUBLIC_ prefix.
# When unset, /admin renders in a degraded "config missing" state.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Analytics IDs (all public — appear in the browser bundle) ─────────────
# EACH ONE IS ENV-ONLY, no hardcoded fallback in code. Set the four below on
# the PRODUCTION environment; leave Preview + Local blank so dev traffic
# doesn't contaminate the production stream (violated invariant otherwise).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_YANDEX_METRICA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_POSTHOG_KEY=
# Optional — override the PostHog host if you self-host or use the EU cloud.
NEXT_PUBLIC_POSTHOG_HOST=

# ─── Search Console verification tokens (public strings) ───────────────────
# Placed in <meta> during page render. Rotating either is a Vercel change,
# not a redeploy — env-only.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ─── Payment gateway (public merchant addresses) ───────────────────────────
# These identify the checkout endpoint only; secrets stay server-side in
# Supabase function secrets (CLICK_SECRET_KEY, PAYME_KEY, RAHMAT_SECRET).
NEXT_PUBLIC_CLICK_SERVICE_ID=
NEXT_PUBLIC_CLICK_MERCHANT_ID=
NEXT_PUBLIC_PAYME_MERCHANT_ID=
# Flag that turns on the Rahmat (Multicard) hosted-checkout path via the
# `rahmat-invoice` edge fn. Value is a "1" / empty toggle.
NEXT_PUBLIC_RAHMAT_ENABLED=

# ─── AI text (résumé "About me" assist, job-post drafting) ────────────────
# Web uses GLM (ZhipuAI) rather than Anthropic for the résumé About-me
# assist — the Claude call lives in the Supabase edge fns
# (generate-job-content, parse-resume) which read ANTHROPIC_API_KEY as a
# function secret, not a Vercel env. GLM is a separate provider driven from
# the Next server code. All three vars are optional; unset → the "AI
# Generate" button falls back to the built-in template.
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# ─── Yandex Geocoder (server-only) ─────────────────────────────────────────
# Used by the address-search endpoint that powers the location picker.
# Optional — without it the picker falls back to OSM Nominatim (rate-limited).
YANDEX_GEOCODER_API_KEY=
