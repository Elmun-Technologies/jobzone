# Supabase — public, RLS-protected credentials (safe to ship to the browser).
# Copy to `.env.local` and fill from the Supabase project's API settings.
# When unset, the app still runs: auth/session simply stays disabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Yandex Maps JavaScript API (v2.1) key — switches every map (landing showcase,
# /explore, location pickers) from OSM/Leaflet tiles to Yandex cartography.
# When unset (or the script fails to load), the maps fall back to OSM.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
