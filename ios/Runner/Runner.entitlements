<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		APNs endpoint. Xcode auto-swaps "development" for "production" when
		the build is uploaded to the App Store via Distribution signing.
		Without this key firebase_messaging never receives a device token,
		so the notify-dispatch → FCM pipeline silently no-ops on iOS.
	-->
	<key>aps-environment</key>
	<string>development</string>

	<!--
		Sign in with Apple. Required whenever the app offers any other
		social sign-in (App Store Review Guideline 4.8). The "Default"
		value tells Apple to use the primary Apple ID configured for the
		bundle in the Developer Portal.
	-->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>

	<!--
		Universal Links. Both hosts must be listed so a naked
		yollla.uz URL opens the app on iOS in addition to www.yollla.uz.
		Requires .well-known/apple-app-site-association served from the
		same origins with the app's Team ID (TEAMID.io.jobzone.jobzone).
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:www.yollla.uz</string>
		<string>applinks:yollla.uz</string>
	</array>
</dict>
</plist>
